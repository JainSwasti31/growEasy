# Server port
PORT=4000

# AI provider selection: "openai" | "gemini" | "anthropic"
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...

# Google Gemini
GEMINI_API_KEY=AIza...

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# CORS: comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000

# Optional: secret token used by the /admin/restart endpoint for safely
# restarting the server process to pick up updated environment variables.
# Set to a random value in development if you plan to call the endpoint.
RESTART_TOKEN=changeme

# Retry / backoff tuning (tweak in CI/dev as needed)
# Number of times to retry provider calls (429 allowed). Default: 2
PROVIDER_MAX_RETRIES=2
# Number of times to retry parsing/validation for a successful provider response
PARSE_MAX_RETRIES=1
# ms to wait between batches to avoid throttling
AI_INTER_BATCH_DELAY_MS=200
# ms to wait when provider suggests a long backoff (e.g. Retry-After)
AI_RATE_LIMIT_BACKOFF_MS=65000

# Security note: do NOT commit real secrets to git. Use ./server/.env (gitignored)
